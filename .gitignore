# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
/dist/                       # top-level Python build artifact only — frontend/dist/ is committed
downloads/
eggs/
.eggs/
# Anchor `lib/` and `lib64/` to the project root — without the leading `/`
# they match `frontend/src/lib/` and silently exclude `cn` + `applyTheme`
# helpers from git, leaving the working tree appearing intact while clones
# are missing the file (FP11 § F follow-up).
/lib/
/lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Frontend: source-build artifacts ignored, pre-built bundle committed
frontend/node_modules/
# Top-level node_modules can be created accidentally if a JS/TS tool is
# invoked from the repo root instead of `frontend/` (e.g. `npx vitest` from
# the wrong cwd); ignore so cache files don't slip into commits.
/node_modules/
# (frontend/dist/ is intentionally NOT ignored — see design §11)

# Virtual envs and tooling
.venv/
.env
.envrc
.python-version
.pytest_cache/
.coverage
.coverage.*
coverage.xml
.mypy_cache/
.ruff_cache/
htmlcov/

# Project-specific (never committed)
/data/
/wheels/
/config.yaml
/overrides.yaml
/sessions.yaml
*.log
# Playwright run output at the repo root — appears when `npx playwright`
# is invoked from the wrong cwd. `frontend/test-results/` is handled by
# `frontend/.gitignore` (the screenshot/e2e harnesses' real home).
/test-results/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
# KDE Dolphin folder-metadata (view mode, sort order, etc.) — appears
# whenever a Dolphin user opens a directory in the tree.
.directory

# Audit artifacts (ants /audit writes SARIF + findings here)
.audit_cache/
